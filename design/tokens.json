{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_meta": {
    "name": "tux",
    "version": "0.1.0",
    "description": "Design tokens for tti-ux. Ships TTI as the default institutional theme; other TAMUS themes extend the base.",
    "derivedFrom": {
      "pptxThemes": [
        "TTI-presentation-template-option-1.pptx",
        "TTI-presentation-template-option-2.pptx",
        "TTI-presentation-template-option-3.pptx",
        "TTI-presentation-template-highcontrast-508.pptx",
        "TTI-presentation-overview.pptx"
      ],
      "pdfs": [
        "tti-overview.pdf",
        "tti-factsheet-4pg.pdf",
        "tti-rellis-campus.pdf"
      ]
    }
  },

  "color": {
    "tti": {
      "maroon":       { "$value": "#5C0025", "$description": "Primary brand anchor. Sampled from tti-overview + factsheet; slightly darker than PPTX #5C0825, both are in TTI's accepted range." },
      "maroon-deep":  { "$value": "#500000", "$description": "High-contrast maroon from 508-accessible PPTX. Use for critical UI where AA contrast is non-negotiable." },
      "gold":         { "$value": "#DDAC37", "$description": "Primary accent. TTI signature warm-ochre gold — not bright Aggie yellow." },
      "gold-deep":    { "$value": "#DCAA37", "$description": "High-contrast gold variant." },
      "navy":         { "$value": "#15457E", "$description": "Secondary accent. Used in option-1 PPTX and on infographic sections." },
      "teal":         { "$value": "#4A8892", "$description": "Tertiary / category color. Use sparingly, for data-viz category differentiation." },
      "sage":         { "$value": "#66814F", "$description": "Tertiary / category color." },
      "charcoal":     { "$value": "#221F1F", "$description": "Body copy. Not pure black — softer, matches print collateral." }
    },

    "neutral": {
      "0":   { "$value": "#FFFFFF" },
      "50":  { "$value": "#FAFAFA" },
      "100": { "$value": "#F5F5F5" },
      "200": { "$value": "#E7E6E6", "$description": "PPTX lt2 light fill." },
      "300": { "$value": "#D1D2D4" },
      "400": { "$value": "#A5A5A5", "$description": "PPTX slate." },
      "500": { "$value": "#939597" },
      "600": { "$value": "#7E7E7E" },
      "700": { "$value": "#5D5D5D" },
      "800": { "$value": "#4C4C4E" },
      "900": { "$value": "#221F1F" },
      "1000":{ "$value": "#000000" }
    },

    "semantic": {
      "success": { "$value": "#66814F", "$description": "uses tti.sage" },
      "warning": { "$value": "#DDAC37", "$description": "uses tti.gold" },
      "danger":  { "$value": "#5C0025", "$description": "uses tti.maroon" },
      "info":    { "$value": "#4A8892", "$description": "uses tti.teal" }
    }
  },

  "themes": {
    "tti": {
      "_default": true,
      "brand": {
        "primary":       { "$value": "{color.tti.maroon}" },
        "primary-deep":  { "$value": "{color.tti.maroon-deep}" },
        "accent":        { "$value": "{color.tti.gold}" },
        "accent-deep":   { "$value": "{color.tti.gold-deep}" },
        "secondary":     { "$value": "{color.tti.navy}" }
      },
      "surface": {
        "page":    { "$value": "{color.neutral.0}" },
        "raised":  { "$value": "{color.neutral.0}" },
        "sunken":  { "$value": "{color.neutral.100}" },
        "border":  { "$value": "{color.neutral.200}" }
      },
      "text": {
        "primary":   { "$value": "{color.tti.charcoal}" },
        "secondary": { "$value": "{color.neutral.700}" },
        "muted":     { "$value": "{color.neutral.500}" },
        "inverse":   { "$value": "{color.neutral.0}" },
        "brand":     { "$value": "{color.tti.maroon}" }
      }
    },

    "tti-hc": {
      "_description": "High-contrast theme, derived from the 508-accessible PPTX. For users who opt in, and as our WCAG AAA audit reference.",
      "brand": {
        "primary":       { "$value": "{color.tti.maroon-deep}" },
        "primary-deep":  { "$value": "#3A0000" },
        "accent":        { "$value": "{color.tti.gold-deep}" },
        "accent-deep":   { "$value": "#B88A21" },
        "secondary":     { "$value": "#000000" }
      },
      "surface": {
        "page":   { "$value": "#FFFFFF" },
        "raised": { "$value": "#FFFFFF" },
        "sunken": { "$value": "#F0F0F0" },
        "border": { "$value": "#5D5D5D" }
      },
      "text": {
        "primary":   { "$value": "#000000" },
        "secondary": { "$value": "#221F1F" },
        "muted":     { "$value": "#5D5D5D" },
        "inverse":   { "$value": "#FFFFFF" },
        "brand":     { "$value": "{color.tti.maroon-deep}" }
      }
    },

    "tamu": {
      "_description": "Texas A&M University — verified brand colors. Maroon 500000 is TAMU's canonical anchor.",
      "brand": {
        "primary":       { "$value": "#500000" },
        "primary-deep":  { "$value": "#3D0000" },
        "accent":        { "$value": "#FFFFFF" },
        "accent-deep":   { "$value": "#CCCCCC" },
        "secondary":     { "$value": "#333333" }
      }
    },

    "pvamu": {
      "_description": "Prairie View A&M — PLACEHOLDER values. Confirm with PVAMU Marketing & Communications before releasing a PVAMU-branded build.",
      "_placeholder": true,
      "brand": {
        "primary":       { "$value": "#500778" },
        "primary-deep":  { "$value": "#3A0555" },
        "accent":        { "$value": "#FFD700" },
        "accent-deep":   { "$value": "#C5A600" },
        "secondary":     { "$value": "#333333" }
      }
    },

    "tarleton": {
      "_description": "Tarleton State — PLACEHOLDER values. Confirm with Tarleton brand team.",
      "_placeholder": true,
      "brand": {
        "primary":       { "$value": "#4C1D95" },
        "primary-deep":  { "$value": "#3A1470" },
        "accent":        { "$value": "#FFFFFF" },
        "accent-deep":   { "$value": "#CCCCCC" },
        "secondary":     { "$value": "#333333" }
      }
    },

    "wtamu": {
      "_description": "West Texas A&M — PLACEHOLDER values. Confirm with WTAMU brand team.",
      "_placeholder": true,
      "brand": {
        "primary":       { "$value": "#642667" },
        "primary-deep":  { "$value": "#4A1B4D" },
        "accent":        { "$value": "#8B7537" },
        "accent-deep":   { "$value": "#6A5727" },
        "secondary":     { "$value": "#333333" }
      }
    }
  },

  "font": {
    "family": {
      "sans":    { "$value": "\"Public Sans\", \"Franklin Gothic ATF\", \"Franklin Gothic\", \"Helvetica Neue\", Arial, sans-serif" },
      "display": { "$value": "\"Public Sans\", \"Franklin Gothic ATF\", \"Franklin Gothic\", \"Helvetica Neue\", Arial, sans-serif" },
      "mono":    { "$value": "\"JetBrains Mono\", \"SFMono-Regular\", Consolas, \"Liberation Mono\", monospace" }
    },
    "weight": {
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "xs":   { "$value": "0.75rem" },
      "sm":   { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg":   { "$value": "1.125rem" },
      "xl":   { "$value": "1.25rem" },
      "2xl":  { "$value": "1.5rem" },
      "3xl":  { "$value": "1.875rem" },
      "4xl":  { "$value": "2.25rem" },
      "5xl":  { "$value": "3rem" },
      "6xl":  { "$value": "3.75rem", "$description": "BigStat default" },
      "7xl":  { "$value": "4.5rem",  "$description": "BigStat oversize" }
    },
    "tracking": {
      "tight":  { "$value": "-0.02em" },
      "normal": { "$value": "0" },
      "wide":   { "$value": "0.05em" },
      "wider":  { "$value": "0.1em", "$description": "ALL-CAPS section headers" }
    },
    "leading": {
      "tight":   { "$value": "1.15" },
      "normal":  { "$value": "1.5" },
      "relaxed": { "$value": "1.75" }
    }
  },

  "space": {
    "0":  { "$value": "0" },
    "1":  { "$value": "0.25rem" },
    "2":  { "$value": "0.5rem" },
    "3":  { "$value": "0.75rem" },
    "4":  { "$value": "1rem" },
    "5":  { "$value": "1.25rem" },
    "6":  { "$value": "1.5rem" },
    "8":  { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" },
    "24": { "$value": "6rem" }
  },

  "radius": {
    "none": { "$value": "0" },
    "sm":   { "$value": "0.125rem" },
    "md":   { "$value": "0.375rem" },
    "lg":   { "$value": "0.5rem" },
    "xl":   { "$value": "0.75rem" },
    "full": { "$value": "9999px" }
  },

  "shadow": {
    "sm":  { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)" },
    "md":  { "$value": "0 4px 6px -1px rgba(0,0,0,0.08), 0 2px 4px -1px rgba(0,0,0,0.04)" },
    "lg":  { "$value": "0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.03)" },
    "focus": { "$value": "0 0 0 3px rgba(92,0,37,0.35)", "$description": "TTI maroon focus ring" }
  }
}
